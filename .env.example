# GroupWare 環境変数設定
# このファイルを .env にコピーして使用してください
# cp .env.example .env

# ===========================================
# アプリケーション設定
# ===========================================
GW_APP_URL=http://localhost/groupware

# ===========================================
# メール送信設定
# ===========================================
# 送信方式: smtp | sendmail | mail
GW_MAIL_TRANSPORT=smtp

# 送信元設定
GW_MAIL_FROM_EMAIL=noreply@example.com
GW_MAIL_FROM_NAME=GroupWare
GW_MAIL_REPLY_TO_EMAIL=

# ===========================================
# SMTP設定 (GW_MAIL_TRANSPORT=smtp の場合)
# ===========================================
GW_SMTP_HOST=smtp.example.com
GW_SMTP_PORT=587
GW_SMTP_SECURE=tls
GW_SMTP_AUTH=true
GW_SMTP_USERNAME=
GW_SMTP_PASSWORD=
GW_SMTP_TIMEOUT=30
GW_SMTP_ALLOW_SELF_SIGNED=false

# ===========================================
# sendmail設定 (GW_MAIL_TRANSPORT=sendmail の場合)
# ===========================================
GW_SENDMAIL_PATH=/usr/sbin/sendmail
